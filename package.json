{
  "name": "debuggo",
  "displayName": "Debuggo",
  "description": "A VS Code extension that helps junior testers generate structured test cases by applying standard software testing techniques based on project context.",
  "version": "0.0.4",
  "publisher": "IntelliTest",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "testing",
    "test cases",
    "qa",
    "quality assurance",
    "ai",
    "excel",
    "test design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamedelziat50/intellitest.git"
  },
  "bugs": {
    "url": "https://github.com/mohamedelziat50/intellitest/issues"
  },
  "homepage": "https://github.com/mohamedelziat50/intellitest#readme",
  "type": "module",
  "activationEvents": [
    "onView:debuggoView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Debuggo",
      "properties": {
        "debuggo.backendUrl": {
          "type": "string",
          "default": "https://intellitest-hyvw.onrender.com",
          "description": "Base URL of the Debuggo API (no trailing slash). Default is the hosted backend; use http://localhost:PORT when running Server locally (match Server/.env PORT)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "debuggo-sidebar",
          "title": "Debuggo",
          "icon": "media/debuggo.svg"
        }
      ]
    },
    "views": {
      "debuggo-sidebar": [
        {
          "type": "webview",
          "id": "debuggoView",
          "name": "Debuggo"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "website": "node website-server.js",
    "vsce:publish-patch": "npx @vscode/vsce publish patch --no-git-tag-version"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "express": "^4.21.2",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "xlsx": "^0.18.5",
    "typescript": "^5.9.3"
  }
}
