PORT=3000
NODE_ENV=development

# Optional: max characters per log section in the terminal (extension payload, LLM prompt, LLM response)
# LOG_MAX_SECTION_CHARS=80000

# LLM: "ollama" (local) or "api" (OpenAI-compatible Chat Completions)
LLM_PROVIDER=api

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── External LLM via OpenRouter (recommended when LLM_PROVIDER=api) ─────────────
# 1. Sign in: https://openrouter.ai/
# 2. Keys:    https://openrouter.ai/settings/keys  → create key, paste below as API_KEY
# 3. Models:  https://openrouter.ai/models         → copy the exact "model id" string
#
# Backend builds URL as: API_BASE_URL + "/chat/completions"
# OpenRouter official base: https://openrouter.ai/api/v1
API_BASE_URL=https://openrouter.ai/api/v1
API_KEY=
# Example paid model id (replace with your choice from the catalog):
# API_MODEL=qwen/qwen2.5-coder-7b-instruct
# Free-tier models often use a :free suffix — use the exact id from the model page, e.g.:
# API_MODEL=some-org/some-model:free
API_MODEL=qwen/qwen2.5-coder-7b-instruct
#
# Optional — OpenRouter recommends these for app attribution (leaderboards); not required for API to work
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/intellitest
# OPENROUTER_APP_TITLE=IntelliTest

# Alternative: Groq (OpenAI-compatible)
# API_BASE_URL=https://api.groq.com/openai/v1
# API_KEY=  (from https://console.groq.com/keys)
# API_MODEL=llama-3.3-70b-versatile

# ── Rate Limiter ───────────────────────────────────────────────────────────────
# Sliding window duration in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP (default: 20)
RATE_LIMIT_MAX=20

# ── AI Service ────────────────────────────────────────────────────────────────
# Timeout for a single AI request in milliseconds (default: 30000 = 30 seconds)
# Bump for large project maps or slower models (e.g. 120000).
AI_TIMEOUT_MS=120000
# Number of retry attempts after a bad/invalid AI response (default: 2)
AI_MAX_RETRIES=2

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Connection URI for MongoDB (local or Atlas)
# Local:  mongodb://127.0.0.1:27017/intellitest
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/intellitest?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/intellitest
